<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.FarmMart" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.FarmMart" parent="Base.Theme.FarmMart" />

    <style name="FarmMartTitleText">
        <item name="android:fontFamily">@font/manrope_extrabold</item>
        <item name="android:textSize">25sp</item>
        <item name="android:textColor">@color/black</item> <!-- Or your logo green -->
        <item name="android:letterSpacing">-0.05</item>
    </style>

    <style name="FontMonropeExtraBold">
        <item name="android:fontFamily">@font/manrope_extrabold</item>
        <item name="android:textColor">@color/black</item> <!-- Or your logo green -->
    </style>

    <style name="ManropeRegular">
        <item name="android:fontFamily">@font/manrope_regular</item>
    </style>

    <style name="ManropeBold">
        <item name="android:fontFamily">@font/manrope_bold</item>
    </style>

    <style name="App.CustomIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/nav_bar_hover_icon</item>
        <!-- Remove android: prefix for app attributes -->
        <item name="cornerRadius">20dp</item>
    </style>

    <style name="ProfileIconStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>

    <style name="CategoryItemStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="CategoryIconStyle">
        <item name="android:layout_width">50dp</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:padding">10dp</item>
        <item name="android:background">@drawable/nav_background_rounded</item>
        <item name="android:backgroundTint">#FFFFFF</item>
    </style>

    <style name="CategoryTextStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">10sp</item>
        <item name="android:layout_marginTop">5dp</item>
        <item name="android:textColor">#828282</item>
    </style>

    <style name="HomeCategoryStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="HomeCategoryIcon">
        <item name="android:layout_width">55dp</item>
        <item name="android:layout_height">55dp</item>
        <item name="android:background">@drawable/nav_background_rounded</item>
        <item name="android:backgroundTint">#FFFFFF</item>
        <item name="android:padding">12dp</item>
        <item name="android:elevation">2dp</item>
    </style>

    <style name="HomeCategoryText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">9sp</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:textColor">#828282</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>