<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/white">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/img_farmer_prod"
            android:layout_width="85dp"
            android:layout_height="85dp"
            android:src="@drawable/logo"
            android:scaleType="centerCrop"
            android:visibility="gone" /> <LinearLayout
        android:id="@+id/layout_details"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_farmer_prod_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Organic Pechay"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#141414" />

        <TextView
            android:id="@+id/tv_farmer_prod_cat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vegetables"
            android:textColor="#828282"
            android:textSize="13sp"
            android:layout_marginTop="2dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginEnd="24dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PRICE"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#828282"/>
                <TextView
                    android:id="@+id/tv_farmer_prod_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₱20 /kg"
                    android:textColor="#435334"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STOCK"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#828282"/>
                <TextView
                    android:id="@+id/tv_farmer_prod_stock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="25"
                    android:textColor="#141414"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

        <TextView
            android:id="@+id/tv_product_status_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"

            android:layout_alignTop="@id/layout_details"

            android:text="ACTIVE"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#435334"
            android:background="@drawable/bg_status_active"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignBottom="@id/layout_details"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_circle_action"
                android:layout_marginEnd="8dp">
                <ImageView
                    android:id="@+id/btn_edit_prod"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@drawable/edit" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_circle_action_delete">
                <ImageView
                    android:id="@+id/btn_delete_prod"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@drawable/delete"
                    app:tint="#D32F2F"/>
            </FrameLayout>
        </LinearLayout>
    </RelativeLayout>
</androidx.cardview.widget.CardView>