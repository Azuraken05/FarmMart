<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF8F5">

    <!-- Top Toolbar Header -->
    <RelativeLayout
        android:id="@+id/chat_toolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#FAF8F5"
        android:paddingHorizontal="12dp">

        <ImageView
            android:id="@+id/btn_chat_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_centerVertical="true"
            android:padding="6dp"
            android:src="@drawable/arrow_back"
            app:tint="#435334"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Back Button" />

        <!-- Circular Profile Avatar -->
        <androidx.cardview.widget.CardView
            android:id="@+id/chat_user_avatar_container"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_toEndOf="@id/btn_chat_back"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#EAE9E4">
                <TextView
                    android:id="@+id/tv_header_avatar_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="U"
                    android:textColor="#435334"
                    android:textStyle="bold"
                    android:textSize="14sp"/>
            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <!-- User Identity Labels -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_toEndOf="@id/chat_user_avatar_container"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:layout_toStartOf="@id/btn_chat_call">

            <TextView
                android:id="@+id/tv_header_user_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User Name"
                android:textColor="#141414"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_header_user_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OFFLINE"
                android:textColor="#828282"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginTop="1dp"/>
        </LinearLayout>

        <!-- Right Header Actions (Using exact names phone and three_dots_vert) -->
        <ImageView
            android:id="@+id/btn_chat_call"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_toStartOf="@id/btn_chat_options"
            android:layout_centerVertical="true"
            android:layout_marginEnd="10dp"
            android:padding="8dp"
            android:src="@drawable/phone"
            app:tint="#435334"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Call Button" />

        <ImageView
            android:id="@+id/btn_chat_options"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:padding="8dp"
            android:src="@drawable/three_dots_vert"
            app:tint="#435334"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Options Menu" />
    </RelativeLayout>

    <View
        android:id="@+id/header_line"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0EDE6"
        android:layout_below="@id/chat_toolbar"/>

    <!-- Bottom Message Tray Area -->
    <LinearLayout
        android:id="@+id/bottom_input_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:layout_alignParentBottom="true"
        android:background="#FAF8F5">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:background="@drawable/capsule_button_background"
            android:backgroundTint="@color/white"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp">

            <!-- Using exact asset file name -->
            <ImageView
                android:id="@+id/btn_chat_attach"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/file"
                app:tint="#727E6A"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Attach File" />

            <EditText
                android:id="@+id/et_message_box"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:hint="Write a message..."
                android:textColorHint="#A39F97"
                android:textColor="#141414"
                android:textSize="14sp"
                android:paddingStart="12dp"
                android:paddingEnd="4dp"
                android:importantForAutofill="no"
                android:inputType="textShortMessage"/>
        </LinearLayout>

        <!-- Round Send Button Container (Using exact asset send name) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/layout_send_button_click"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            android:clickable="true"
            android:focusable="true">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#435334">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/send"
                    app:tint="@color/white"
                    android:layout_marginStart="2dp"
                    android:contentDescription="Send Message Button" />
            </FrameLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- Message Stream -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_live_message_bubbles"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_input_container"
        android:layout_below="@id/header_line"
        android:paddingVertical="8dp"
        android:clipToPadding="false"/>

</RelativeLayout>