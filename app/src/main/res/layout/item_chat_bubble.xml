<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="4dp">

    <LinearLayout
        android:id="@+id/layout_chat_received"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:maxWidth="280dp">
        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#EAE9E4">
            <TextView
                android:id="@+id/tv_chat_received_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#141414"
                android:textSize="14sp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"/>
        </androidx.cardview.widget.CardView>
        <TextView
            android:id="@+id/tv_chat_received_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="09:41 AM"
            android:textSize="10sp"
            android:textColor="#828282"
            android:layout_marginTop="2dp"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_chat_sent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:maxWidth="280dp">
        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#435334">
            <TextView
                android:id="@+id/tv_chat_sent_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"/>
        </androidx.cardview.widget.CardView>
        <TextView
            android:id="@+id/tv_chat_sent_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="09:42 AM"
            android:textSize="10sp"
            android:textColor="#828282"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="4dp"/>
    </LinearLayout>

</LinearLayout>