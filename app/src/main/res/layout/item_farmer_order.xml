<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_detail_order_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ORD-2026-004"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#141414"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true" />

        <TextView
            android:id="@+id/tv_detail_status_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignTop="@id/tv_detail_order_id"
            android:text="PENDING SHIPMENT"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#D32F2F"
            android:background="#FCECEB"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"/>

        <TextView
            android:id="@+id/tv_detail_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="April 18, 2026"
            android:textSize="12sp"
            android:textColor="#828282"
            android:layout_below="@id/tv_detail_order_id"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:id="@+id/layout_cust_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_detail_date"
            android:layout_marginTop="12dp"
            android:background="#F5F4F0"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/logo"
                app:tint="#435334" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView
                    android:id="@+id/tv_detail_cust_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="John Mark Silva"
                    android:textStyle="bold"
                    android:textColor="#141414"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/tv_detail_cust_address"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mabuhay Rd."
                    android:textColor="#828282"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_items_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/layout_cust_banner"
            android:layout_marginTop="12dp"
            android:text="2 ITEMS"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#828282" />

        <TextView
            android:id="@+id/tv_detail_product_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_items_header"
            android:layout_marginTop="4dp"
            android:text="2x Organic Curly Kale\n1x Heirloom Tomatoes"
            android:textSize="14sp"
            android:textColor="#141414"
            android:lineSpacingMultiplier="1.2" />

        <LinearLayout
            android:id="@+id/layout_payment_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_detail_product_list"
            android:layout_marginTop="12dp"
            android:background="#F5F4F0"
            android:padding="12dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PAYMENT"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#828282" />
            <TextView
                android:id="@+id/tv_detail_payment_method"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cash on Delivery"
                android:textColor="#141414"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_below="@id/layout_payment_banner"
            android:layout_marginTop="16dp"
            android:layout_alignParentStart="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ORDER TOTAL"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#828282" />
            <TextView
                android:id="@+id/tv_detail_total_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱969.90"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#435334"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="130dp"
            android:layout_height="50dp"
            app:cardCornerRadius="25dp"
            app:cardElevation="0dp"
            app:cardPreventCornerOverlap="false"
            android:layout_below="@id/layout_payment_banner"
            android:layout_marginTop="16dp"
            android:layout_alignParentEnd="true">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_ship_order"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#435334"
                android:text="Ship Order"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textAllCaps="false" />
        </androidx.cardview.widget.CardView>

    </RelativeLayout>
</androidx.cardview.widget.CardView>