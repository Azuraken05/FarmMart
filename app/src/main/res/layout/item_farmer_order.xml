<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="10dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tv_order_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ORD-2026-004"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#141414" />

            <TextView
                android:id="@+id/tv_order_status_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="PENDING SHIPMENT"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#D32F2F"
                android:background="@drawable/bg_status_pending"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"/>
        </RelativeLayout>

        <TextView
            android:id="@+id/tv_order_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="April 19, 2026"
            android:textSize="12sp"
            android:textColor="#828282"
            android:layout_marginBottom="15dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F4F0"
            android:padding="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="15dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/logo" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tv_customer_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="John Mark Silva"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#141414"/>

                <TextView
                    android:id="@+id/tv_customer_address"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mabuhay Rd."
                    android:textSize="12sp"
                    android:textColor="#828282"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_order_item_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 ITEMS"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#828282"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_item_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2x Organic Curly Kale\n1x Heirloom Tomatoes"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:textColor="#4F4F4F"
            android:layout_marginBottom="15dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F4F0"
            android:padding="12dp"
            android:orientation="vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PAYMENT"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#828282"/>

            <TextView
                android:id="@+id/tv_order_payment_method"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cash on Delivery"
                android:textSize="14sp"
                android:textColor="#141414"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ORDER TOTAL"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#828282"/>

                <TextView
                    android:id="@+id/tv_order_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₱969.90"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#435334"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_ship_order"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/nav_background_rounded"
                android:backgroundTint="#435334"
                android:paddingHorizontal="24dp"
                android:text="Ship Order"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="14sp" />
        </RelativeLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>