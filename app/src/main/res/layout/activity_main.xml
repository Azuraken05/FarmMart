<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:layout_editor_absoluteX="0dp"
        android:background="@color/background"
        tools:layout_editor_absoluteY="16dp"
        android:padding="2dp"
        >

        <!-- Logo Layout -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="50dp">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginLeft="100dp"
                android:src="@drawable/logo" />

            <TextView
                style="@style/FarmMartTitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginLeft="160dp"
                android:text="FarmMart"
                android:textColor="@color/farm_mart_green" />
        </FrameLayout>
        <!-- Welcomed Layout -->
        <FrameLayout
            android:layout_marginTop="140dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome Back"
                android:layout_marginLeft="30dp"
                android:textSize="30dp"
                style="@style/FontMonropeExtraBold"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign in to your account"
                android:layout_marginLeft="30dp"
                android:layout_marginTop="45dp"
                android:textColor="@color/grayish"
                style="@style/ManropeRegular"
                />
        </FrameLayout>

        <!-- EditText Layout -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="230dp"
            >
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EMAIL ADDRESS"
                android:layout_marginLeft="40dp"
                android:letterSpacing="0.2"
                style="@style/FontMonropeExtraBold"
                android:textColor="@color/font_color_gray"
                />
            <EditText
                android:id="@+id/email_address"
                android:layout_width="290dp"
                android:layout_height="wrap_content"
                android:background="@drawable/edittext_roundborder"
                android:padding="12dp"
                android:hint="example@gmail.com"
                android:layout_marginLeft="40dp"
                android:layout_marginTop="30dp"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PASSWORD"
                android:layout_marginLeft="40dp"
                android:letterSpacing="0.2"
                style="@style/FontMonropeExtraBold"
                android:textColor="@color/font_color_gray"
                android:layout_marginTop="90dp"
                />
            <EditText
                android:id="@+id/password"
                android:layout_width="290dp"
                android:layout_height="wrap_content"
                android:background="@drawable/edittext_roundborder"
                android:padding="12dp"
                android:hint="*******"
                android:layout_marginLeft="40dp"
                android:layout_marginTop="120dp"
                />
        </FrameLayout>

        <!--BUTTON LAYOUT-->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="420dp"
            >
            <Button
                android:id="@+id/SignIn"
                android:layout_width="290dp"
                android:layout_height="60dp"
                android:text="Sign In"
                style="@style/ManropeBold"
                android:layout_marginLeft="40dp"
                android:backgroundTint="@color/farm_mart_green"
                android:textColor="@color/white" />

            <Button
                android:layout_width="290dp"
                android:layout_height="60dp"
                android:text="Continue with Google"
                style="@style/ManropeBold"
                android:layout_marginLeft="40dp"
                android:layout_marginTop="80dp"
                android:textColor="@color/black"
                android:background="@drawable/button_border"
                app:backgroundTint="@null"
                />
        </FrameLayout>

        <!-- REGISTER LAYOUT-->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="600dp"
            >
            <TextView
                android:id="@+id/registerTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/ManropeBold"
                android:text="@string/no_account_register"
                android:textColor="@color/black"
                android:layout_gravity="center"
                />
        </FrameLayout>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>