<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="40dp"
        android:gravity="start">

        <!-- Logo Layout -->
        <LinearLayout
            android:layout_gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="30dp">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/logo" />

            <TextView
                style="@style/FarmMartTitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="FarmMart"
                android:textColor="@color/farm_mart_green" />
        </LinearLayout>

        <!-- Welcome Text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome Back"
            android:textSize="30sp"
            style="@style/FontMonropeExtraBold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign in to your account"
            android:textColor="@color/grayish"
            style="@style/ManropeRegular"
            android:layout_marginBottom="30dp" />

        <!-- Email -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMAIL ADDRESS"
            android:letterSpacing="0.2"
            style="@style/FontMonropeExtraBold"
            android:textColor="@color/font_color_gray"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/email_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/edittext_roundborder"
            android:padding="12dp"
            android:hint="example@gmail.com"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="20dp" />

        <!-- Password -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PASSWORD"
            android:letterSpacing="0.2"
            style="@style/FontMonropeExtraBold"
            android:textColor="@color/font_color_gray"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/edittext_roundborder"
            android:padding="12dp"
            android:hint="*******"
            android:inputType="textPassword"
            android:layout_marginBottom="30dp" />

        <!-- Sign In Button -->
        <Button
            android:id="@+id/SignIn"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Sign In"
            style="@style/ManropeBold"
            android:backgroundTint="@color/farm_mart_green"
            android:textColor="@color/white"
            android:layout_marginBottom="16dp" />

        <!-- Google Button -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Continue with Google"
            style="@style/ManropeBold"
            android:textColor="@color/black"
            android:background="@drawable/button_border"
            app:backgroundTint="@null"
            android:layout_marginBottom="24dp" />

        <!-- Register -->
        <TextView
            android:id="@+id/registerTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/ManropeBold"
            android:text="@string/no_account_register"
            android:textColor="@color/black"
            android:layout_gravity="center_horizontal" />

    </LinearLayout>
</ScrollView>