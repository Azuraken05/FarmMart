<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FDFBF7"
    android:padding="16dp"
    tools:context=".FarmerOrdersFragment">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="15dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Orders"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#141414"
            android:layout_centerVertical="true"/>

        <TextView
            android:id="@+id/tv_total_orders_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="0 ITEMS"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#435334" />
    </RelativeLayout>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/farmer_orders_tab_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:tabSelectedTextColor="#435334"
        app:tabTextColor="#828282"
        app:tabIndicatorColor="#435334"
        app:tabIndicatorHeight="3dp"
        app:tabMode="fixed"
        app:tabGravity="fill"
        android:layout_marginBottom="10dp" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/farmer_orders_view_pager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="80dp" />

</LinearLayout>